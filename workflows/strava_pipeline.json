{
  "name": "StravaSquad Lakehouse Pipeline",
  "tasks": [
    {
      "task_key": "01_ingest_to_bronze",
      "notebook_task": {
        "notebook_path": "/Workspace/Repos/StravaSquad-Lakehouse/notebooks/01_ingest_to_bronze"
      },
      "job_cluster_key": "pipeline_cluster"
    },
    {
      "task_key": "02_bronze_to_silver",
      "depends_on": [{"task_key": "01_ingest_to_bronze"}],
      "notebook_task": {
        "notebook_path": "/Workspace/Repos/StravaSquad-Lakehouse/notebooks/02_bronze_to_silver"
      },
      "job_cluster_key": "pipeline_cluster"
    },
    {
      "task_key": "03_silver_to_gold",
      "depends_on": [{"task_key": "02_bronze_to_silver"}],
      "notebook_task": {
        "notebook_path": "/Workspace/Repos/StravaSquad-Lakehouse/notebooks/03_silver_to_gold"
      },
      "job_cluster_key": "pipeline_cluster"
    },
    {
      "task_key": "04_predict_pb",
      "depends_on": [{"task_key": "03_silver_to_gold"}],
      "notebook_task": {
        "notebook_path": "/Workspace/Repos/StravaSquad-Lakehouse/notebooks/04_predict_pb"
      },
      "job_cluster_key": "pipeline_cluster"
    },
    {
      "task_key": "05_data_quality_tests",
      "depends_on": [{"task_key": "04_predict_pb"}],
      "notebook_task": {
        "notebook_path": "/Workspace/Repos/StravaSquad-Lakehouse/tests/test_silver_quality"
      },
      "job_cluster_key": "pipeline_cluster"
    }
  ],
  "job_clusters": [
    {
      "job_cluster_key": "pipeline_cluster",
      "new_cluster": {
        "spark_version": "14.3.x-scala2.12",
        "node_type_id": "i3.xlarge",
        "num_workers": 0,
        "spark_conf": {
          "spark.master": "local[*]",
          "spark.databricks.cluster.profile": "singleNode"
        },
        "custom_tags": {"ResourceClass": "SingleNode"}
      }
    }
  ],
  "max_concurrent_runs": 1,
  "format": "MULTI_TASK"
}
